DATA_DIR=./data
MODEL_DIR=./models
REPORT_DIR=./reports
SEASONS_START=2015
SEASONS_END=2025
# Open-Meteo requires no key. Leave blank.
WEATHER_CACHE=./data/raw/weather.parquet

# Odds API for market-aware adjustment (free tier: 500 requests/month)
# Get a key at https://the-odds-api.com/
ODDS_API_KEY=

# Admin password for /admin key-management page.
# If blank, admin access is disabled entirely.
ADMIN_PASSWORD=